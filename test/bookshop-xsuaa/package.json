{
  "name": "bookshop-xsuaa",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@gavdi/cap-mcp": "file:../..",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "db-ext": {
        "[development]": {
          "model": "db/sqlite"
        },
        "[production]": {
          "model": "db/hana"
        }
      },
      "[production]": {
        "auth": "xsuaa"
      }
    },
    "mcp": {
      "auth": "inherit",
      "base_path": "/mcp",
      "trusted_proxies": true,
      "oauth": {
        "proxy": "disabled",
        "protected_resource": "enabled"
      }
    }
  }
}
